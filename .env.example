# Optional: provide a token directly to skip the OAuth device flow entirely
# Obtain via: https://oauth.yandex.ru/authorize?response_type=token&client_id=YOUR_CLIENT_ID
# Valid for 6 months.
# YANDEX_WEBMASTER_API_KEY=

# Optional: override the directory where token.json is stored
# Defaults to the OS config dir (~/.config/yandex-webmaster-mcp on Linux/Mac,
# %APPDATA%\yandex-webmaster-mcp on Windows)
# YANDEX_WEBMASTER_TOKEN_DIR=
